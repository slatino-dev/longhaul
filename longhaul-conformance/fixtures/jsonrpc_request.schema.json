{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcp-2026-07-28/jsonrpc-request",
  "title": "JSON-RPC 2.0 Request (MCP profile)",
  "description": "A JSON-RPC 2.0 request object. Batch arrays are not allowed (removed in MCP 2025-06-18).",
  "type": "object",
  "required": ["jsonrpc", "id", "method"],
  "additionalProperties": true,
  "properties": {
    "jsonrpc": {
      "type": "string",
      "const": "2.0"
    },
    "id": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object"
    }
  }
}
