{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcp-2026-07-28/discover-result",
  "title": "server/discover result",
  "type": "object",
  "required": ["protocolVersion", "serverInfo", "capabilities"],
  "additionalProperties": true,
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "2026-07-28"
    },
    "serverInfo": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tools": {
          "type": "object",
          "properties": {
            "listChanged": { "type": "boolean" }
          }
        },
        "tasks": { "type": "object" }
      }
    },
    "instructions": { "type": "string" }
  }
}
